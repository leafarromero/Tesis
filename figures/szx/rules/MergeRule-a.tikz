\begin{tikzpicture}
	\begin{pgfonlayer}{nodelayer}
		\node [style=ground bold, rotate=-90] (1) at (0, 0) {\ground};
		\node [style=Z phase dot bold] (2) at (1, 0) {$\alpha$};
		\node [style=none] (3) at (2, 0) {};
	\end{pgfonlayer}
	\begin{pgfonlayer}{edgelayer}
		\draw [style=bold edge, out=0,in=180,looseness=1.50] (1.center) to (2);
		\draw [style=bold edge, out=0,in=180,looseness=1.50] (2) to (3.center);
	\end{pgfonlayer}
\end{tikzpicture}
